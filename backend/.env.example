# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# Server
PORT=4000
FRONTEND_URL=http://localhost:5500/Frontend/index.html

# Google OAuth (console.cloud.google.com -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback

# Microsoft OneDrive OAuth (portal.azure.com -> App registrations)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:4000/api/onedrive/callback

# Dropbox (dropbox.com/developers/apps)
DROPBOX_ACCESS_TOKEN=

# AWS S3 (console.aws.amazon.com/iam)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
